# ─── required ────────────────────────────────────────────────────────────────

# Secret used to sign JWT tokens. Must be at least 32 chars.
# Generate one with:  openssl rand -hex 32
JWT_SECRET=replace-this-with-a-64-char-random-string-32-bytes-hex

# Initial admin account. ONLY used on first startup when no admin exists yet.
# After the admin is created, these can be removed (or changed and ignored).
# To change the admin password later, log in as admin and use the
# "change password" UI in the app (or POST /api/auth/change-password).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-please

# ─── optional ────────────────────────────────────────────────────────────────

PORT=3000

# JWT token lifetime. Accepts ms-style strings: 7d, 30d, 12h, etc.
JWT_EXPIRES_IN=30d

# Path to SQLite file (will be created on first run).
# DATABASE_PATH=./data/anchor.db

# Where uploaded cover images get stored.
# UPLOAD_DIR=./data/uploads

# Max upload size in MB (default 5).
# MAX_UPLOAD_SIZE_MB=5

# ─── backups (optional) ──────────────────────────────────────────────────────
# Automatic SQLite backups via VACUUM INTO. Set interval to 0 to disable.
# BACKUP_INTERVAL_HOURS=24
# BACKUP_KEEP=7
# BACKUP_DIR=./data/backups
